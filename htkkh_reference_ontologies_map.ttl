htkkh:Brick_Schema a htkkh:ReferenceOntology ;
    dcterms:title "Brick Schema" ;
    htkkh:category "AI Factory" ;
    htkkh:publisher "Brick Consortium" ;
    htkkh:officialSource <https://brickschema.org/> ;
    htkkh:wikiPage <https://dsext001-eu1-215dsi0708-3dswym.3dexperience.3ds.com/community/swym:215dsi0708:DSEXT001:community:JsMPZSruR1Kj88ZS1muhWQ?content=swym:215dsi0708:DSEXT001:wikitree:azyjLHMTQoGNkGIy3YENlA> ;
    htkkh:parentOntology "AI Factory (End-Object Ontology)" ;
    htkkh:stabilityStatus "stable" ;
    htkkh:usageStatus "open" ;
    htkkh:endObject "AI Factories" ;
    htkkh:imd "Infrastructure System Architecture" ;
    htkkh:imd "Compute Performance & Sustainability" ;
    dcterms:description "Brick Schema is an open OWL ontology for modeling buildings, infrastructure, and their systems, including spaces, equipment, power distribution, cooling, HVAC, and sensors. It provides a formal semantic foundation to represent and reason over the physical and infrastructural structure of AI factories and data centers." .

htkkh:CIM a htkkh:ReferenceOntology ;
    dcterms:title "CIM" ;
    htkkh:category "AI Factory" ;
    htkkh:publisher "IEC" ;
    htkkh:officialSource <https://www.iec.ch/standardsdev/publications/> ;
    htkkh:wikiPage <https://dsext001-eu1-215dsi0708-3dswym.3dexperience.3ds.com/community/swym:215dsi0708:DSEXT001:community:JsMPZSruR1Kj88ZS1muhWQ?content=swym:215dsi0708:DSEXT001:wikitree:CLVX0LTORSG9cyf_aponEg> ;
    htkkh:parentOntology "AI Factory (End-Object Ontology)" ;
    htkkh:stabilityStatus "stable" ;
    htkkh:usageStatus "licensed" ;
    htkkh:endObject "AI Factories" ;
    htkkh:imd "Infrastructure System Architecture" ;
    htkkh:imd "Compute Performance & Sustainability" ;
    dcterms:description "The Common Information Model (CIM) is a formal object-oriented schema developed by the Distributed Management Task Force (DMTF) to represent managed elements in IT environments, including computer systems, racks, chassis, processors, memory, power supplies, networking components, and cooling subsystems. CIM provides a strong reference model for AI Factory physical and logical infrastructure components." .

