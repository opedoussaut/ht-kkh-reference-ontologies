htkkh:ORIONT a htkkh:ReferenceOntology ;
    dcterms:title "ORIONT" ;
    htkkh:category "Circularity / Sustainability" ;
    htkkh:publisher "Research / Community" ;
    htkkh:wikiPage <https://dsext001-eu1-215dsi0708-3dswym.3dexperience.3ds.com/community/swym:215dsi0708:DSEXT001:community:JsMPZSruR1Kj88ZS1muhWQ?content=swym:215dsi0708:DSEXT001:wikitree:zmTUJGTVSSeV6oolo9UT_w> ;
