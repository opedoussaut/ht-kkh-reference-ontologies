    dcterms:title "ELI Ontology" ;
    htkkh:category "Regulatory / Normative" ;
    htkkh:publisher "Publications Office of the European Union" ;
    htkkh:officialSource <https://op.europa.eu/en/web/eu-vocabularies/eli> ;
