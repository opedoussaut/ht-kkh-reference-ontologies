    htkkh:stabilityStatus "not stable" ;
    htkkh:usageStatus "restricted" ;
    htkkh:endObject "AI Factories" ;
    htkkh:endObject "Semiconductors" ;
    htkkh:endObject "Personal Electronics" ;
    htkkh:endObject "General Purpose Robotics" ;
    htkkh:imd "Circular Design" ;
    dcterms:description "ORIENTING provides a structured ontology for Life Cycle Sustainability Assessment. It formalizes concepts related to environmental, social, and economic impacts across lifecycle stages. The ontology supports interoperability of LCSA data, impact indicators, system boundaries, and sustainability modeling workflows." .

