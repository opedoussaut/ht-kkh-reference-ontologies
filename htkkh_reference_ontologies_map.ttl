htkkh:ReferenceOntology a rdfs:Class .
htkkh:stabilityStatus a rdf:Property .
htkkh:usageStatus a rdf:Property .
htkkh:category a rdf:Property .
htkkh:publisher a rdf:Property .
htkkh:officialSource a rdf:Property .
htkkh:wikiPage a rdf:Property .
htkkh:parentOntology a rdf:Property .
htkkh:endObject a rdf:Property .
htkkh:imd a rdf:Property .

